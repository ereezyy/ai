# Environment variables for AI Toolkit

# Your API key for the Groq service. Essential for autonomous operations and NLP processing.
GROQ_API_KEY="your_groq_api_key_here"

# Set to 'true' to suppress the verbose welcome banner and dramatic CLI output.
# Useful for CI/CD environments or when a more subdued experience is desired.
AI_TOOLKIT_QUIET="false" # or "true"
